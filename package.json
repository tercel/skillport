{
  "name": "agent-skill-bundler",
  "version": "0.2.0",
  "description": "Port Claude Code skill plugins to other agent platforms — Codex is the implemented target, with a target-agnostic pipeline ready for more adapters. Produces namespace-prefixed flat skills, inlined shared includes, cross-plugin reference rewriting, and self-enforced conversion gates.",
  "type": "module",
  "bin": {
    "agent-skill-bundler": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.mjs",
    "convert": "node dist/index.js convert",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "codex",
    "skills",
    "agent-skills",
    "converter",
    "cli"
  ],
  "author": "tercel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tercel/agent-skill-bundler.git"
  },
  "bugs": {
    "url": "https://github.com/tercel/agent-skill-bundler/issues"
  },
  "homepage": "https://github.com/tercel/agent-skill-bundler#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}